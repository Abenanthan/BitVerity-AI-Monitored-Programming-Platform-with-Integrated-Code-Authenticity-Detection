# ─── App ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Submission Rate Limiting ────────────────────────
SUBMIT_RATE_LIMIT=5      # max submissions per window
SUBMIT_RATE_WINDOW=60    # window in seconds

# ─── PostgreSQL (shared with Python service) ────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/codeverify?schema=public"

# ─── Redis ──────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ────────────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── GitHub OAuth (optional) ────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ─── Judge0 (code execution) ────────────────────────
JUDGE0_API_URL=https://judge0.p.rapidapi.com
JUDGE0_API_KEY=125f2ca29amsh4c8bca955a4e920p11a882jsn63a4138ef0f1

# ─── Python Detection Microservice ──────────────────
DETECTION_SERVICE_URL=http://localhost:8000

# ─── CORS ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
